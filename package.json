  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run format && npm run scrub:fix && npm run typecheck && npm run lint && npm run lint:styles && npm run format:check",
    "build": "vite build && tsc --emitDeclarationOnly",
    "scrub": "unicode-scrub \"src/**/*\" \"index.html\"",
    "scrub:fix": "unicode-scrub --fix \"src/**/*\" \"index.html\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@lnpg/unicode-scrub": "^1.0.0",
    "@types/bootstrap": "^5.2.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "bootstrap": "^5.3.8",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.0.0",
    "postcss-scss": "^4.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.83.0",
    "sass-embedded": "^1.83.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
