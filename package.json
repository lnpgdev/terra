{
  "name": "@lnpg/terra",
  "version": "0.9.0",
  "description": "Framework-agnostic UI Kit for LNPG internal applications.",
  "homepage": "https://github.com/lnpgdev/terra#readme",
  "bugs": {
    "url": "https://github.com/lnpgdev/terra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lnpgdev/terra.git"
  },
  "license": "ISC",
  "author": "LNPG Development Team",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/types/index.d.ts",
  "style": "./dist/terra.css",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/terra.css",
    "./components/alert": {
      "types": "./dist/types/components/alert/index.d.ts",
      "import": "./dist/components/alert/index.es.js",
      "require": "./dist/components/alert/index.cjs.js"
    },
    "./components/logo": {
      "types": "./dist/types/components/logo/index.d.ts",
      "import": "./dist/components/logo/index.es.js",
      "require": "./dist/components/logo/index.cjs.js"
    },
    "./components/close-button": {
      "types": "./dist/types/components/close-button/index.d.ts",
      "import": "./dist/components/close-button/index.es.js",
      "require": "./dist/components/close-button/index.cjs.js"
    },
    "./components/horizontal-rule": {
      "types": "./dist/types/components/horizontal-rule/index.d.ts",
      "import": "./dist/components/horizontal-rule/index.es.js",
      "require": "./dist/components/horizontal-rule/index.cjs.js"
    },
    "./components/placeholder": {
      "types": "./dist/types/components/placeholder/index.d.ts",
      "import": "./dist/components/placeholder/index.es.js",
      "require": "./dist/components/placeholder/index.cjs.js"
    },
    "./components/spinner": {
      "types": "./dist/types/components/spinner/index.d.ts",
      "import": "./dist/components/spinner/index.es.js",
      "require": "./dist/components/spinner/index.cjs.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run scrub && npm run typecheck && npm run lint && npm run lint:styles && npm run format:check",
    "build": "vite build && tsc --emitDeclarationOnly",
    "scrub": "unicode-scrub \"src/**/*\" \"index.html\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@lnpg/unicode-scrub": "^1.0.0",
    "@types/bootstrap": "^5.2.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "bootstrap": "^5.3.8",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.0.0",
    "postcss-scss": "^4.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.83.0",
    "sass-embedded": "^1.83.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
