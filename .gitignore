# The repisitory's ignored file and folder patterns.
#
# @link       https://www.atlassian.com/git/tutorials/saving-changes/gitignore
# @version    1.0.0 (file)
# @since      1.0.0 (release)
 
#--
# NODE / NPM
#
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
 
#--
# BUILD OUTPUT
#
dist/
build/
out/
 
#--
# TYPESCRIPT
#
*.tsbuildinfo
*.tsbuildinfo.types
*.d.ts.map
tsconfig.tsbuildinfo
 
#--
# ENVIRONMENT / CONFIG
#
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.npmrc
!.npmrc.example

#--
# IDES / EDITORS
#
.vscode/
.idea/
*.sw?
.DS_Store
Thumbs.db
 
#--
# TESTING / VITEST
#
coverage/
.vitest/
 
#--
# DOCS / VITEPRESS / TYPEDOC / SASSCRIBE
#
docs/.vitepress/cache/
docs/.vitepress/dist/
docs/api/ts/
docs/api/scss/
sassdoc/
sasscribe-temp/
typedoc-temp/
 
#--
# LOGS / MISC
#
*.log
*.tgz
*.pid
*.seed
*.pid.lock
 
#--
# LOCAL TOOLS / CACHES
#
.cache/
.tmp/
.temp/
.eslintcache
vite.config.timestamp-*.mjs
 
#--
# OS / SYSTEM JUNK
#
ehthumbs.db
Icon?
Desktop.ini